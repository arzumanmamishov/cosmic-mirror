# Server
PORT=8080
ENVIRONMENT=dev
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://cosmic:cosmic_secret@localhost:5432/cosmic_mirror?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Astrology API
ASTROLOGY_API_KEY=your-astrology-api-key
ASTROLOGY_API_BASE_URL=https://json.astrologyapi.com/v1

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Rate Limiting
FREE_TIER_CHAT_LIMIT=3
FREE_TIER_RATE_LIMIT=60
PREMIUM_RATE_LIMIT=120
